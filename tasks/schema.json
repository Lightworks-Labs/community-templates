{
  "databases": [
    {
      "id": "tasks",
      "name": "Tasks",
      "description": "Track action items, bugs, and follow-ups",
      "fields": [
        { "id": "title", "name": "Title", "type": "text", "required": true },
        { "id": "status", "name": "Status", "type": "multi-select", "options": ["todo", "in-progress", "done", "cancelled"] },
        { "id": "priority", "name": "Priority", "type": "multi-select", "options": ["low", "medium", "high", "critical"] },
        { "id": "assignee", "name": "Assignee", "type": "text" },
        { "id": "due_date", "name": "Due Date", "type": "date" },
        { "id": "description", "name": "Description", "type": "text" }
      ]
    }
  ],
  "relationships": []
}
